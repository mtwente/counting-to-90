@article{hviidDetArktiskeVindue2022,
  title = {Det Arktiske Vindue -- et Kig Til {{Gr\o nlands}} Udenrigspolitik},
  author = {Hviid, Alexander Niels-Jacob},
  year = 2022,
  month = feb,
  journal = {Politica},
  volume = {54},
  number = {1},
  pages = {44--63},
  issn = {2246-042X, 0105-0710},
  doi = {10.7146/politica.v54i1.130593},
  urldate = {2026-02-27},
  abstract = {I b\aa de hjemmestyreloven og senere selvstyreloven er det sl\aa et fast, at Gr\o nland havde og har et vist juridisk handlerum til selv at f\o re udenrigspolitik. Det har imidlertid altid v\ae ret uklart, pr\ae cist hvor stort dette udenrigspolitiske handlerum er. Denne juridiske uklarhed kom til udtryk i praksis i casen det ''arktiske vindue'' fra 1999. Dengang som nu havde K\o benhavn og Nuuk divergerende opfattelser af Gr\o nlands udenrigspolitiske handlerum. Denne forskellighed blev ikke kommunikeret \aa bent men snarere fejet ind under gulvt\ae ppet. Den grundl\ae ggende juridiske uklarhed er imidlertid blevet videref\o rt i selvstyreloven, som er g\ae ldende i dag. De dynamikker, som denne artikel belyser, forts\ae tter derfor med at pr\ae ge dansk-gr\o nlandske relationer. Dette bliver mere problematisk efterh\aa nden, som den geopolitiske konkurrence \o ges, og rigsf\ae lleskabet skal h\aa ndtere et stigende antal internationale akt\o rer i Arktis.},
  copyright = {http://politica.dk/}
}

