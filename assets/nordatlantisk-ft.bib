@article{green-pedersenBlokpolitikOgNye2020,
  title = {Blokpolitik Og Nye Politiske Emner. {{Hvordan}} G\aa r Det Med Samarbejdsm\o nstrene i {{Folketinget}}?},
  author = {{Green-Pedersen}, Christoffer and Skj{\ae}veland, Asbj{\o}rn},
  year = 2020,
  month = oct,
  journal = {Politica},
  volume = {52},
  number = {3},
  pages = {311--330},
  issn = {2246-042X, 0105-0710},
  doi = {10.7146/politica.v52i3.130826},
  urldate = {2025-08-27},
  abstract = {Artiklen diskuterer indledningsvis udviklingen i graden af blokpolitik fra 1973 og frem til i dag, hvorefter den unders\o ger, i hvilket omfang lovgivningsarbejdet nu er pr\ae get af ny- og gammelpolitik. Hvor forskelligt placerer partierne sig i lovafstemningerne p\aa{} de to omr\aa der? Er der forskel p\aa{} graden af blokpolitik p\aa{} ny- og gammelpolitik? Artiklen unders\o ger \aa rene 2007-2017 og viser, at der ikke er kommet rod i blokkene. Ingen partier har p\aa{} nogen af omr\aa derne flyttet sig ind mellem partier i den anden blok p\aa{} hverken ny- eller gammelpolitik, men et endimensionalt perspektiv er udfordret -- til tider v\ae sentligt udfordret -- af forskellige partiplaceringer p\aa{} de to omr\aa der inden for blokkene. En analyse af graden af blokpolitik p\aa{} ny- og gammelpolitik viser endvidere, at der ikke er v\ae sentlig forskel p\aa{} graden af blokpolitik p\aa{} de to omr\aa der.},
  copyright = {http://politica.dk/}
}

