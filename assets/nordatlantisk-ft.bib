@article{westFaeroskPolitikMellem2020,
  title = {F\ae r\o sk Politik -- Mellem Gamle Politiske Traditioner Og Ny Forvaltningspraksis},
  author = {West, Hallbera},
  year = 2020,
  month = dec,
  journal = {\O konomi \& Politik},
  volume = {93},
  number = {4},
  pages = {11--23},
  issn = {2596-8815, 0030-1906},
  doi = {10.7146/okonomi-og-politik.v93i4.123410},
  urldate = {2024-01-06},
  abstract = {Formelle diskussioner til trods, s\aa{} fungerer det f\ae r\o ske politiske system de facto som et selvst\ae ndigt politisk system, der lovgiver, forvalter og tager beslutninger, der p\aa virker den enkelte f\ae rings liv og muligheder. Denne artikel pr\ae senterer en analyse af det f\ae r\o ske politiske system og en introduktion af politiske tendenser. Det f\ae r\o ske politiske system er et eksempel p\aa{} et parlamentarisk system med et flerpartisystem, men mens de politiske traditioner er veletablerede, s\aa{} er forvaltningspraksis af nyere dato. Den politiske dagsorden de sidste mange \aa r har v\ae ret kendetegnet af politisk polarisering i forhold til fordelingsm\ae ssige og v\ae rdipolitiske sp\o rgsm\aa l. Samtidig har der udviklet sig en form for sj\ae lden tv\ae rpolitisk enighed i forhold til. Danmark, hvor der \o nskes og stilles krav om st\o rre indflydelse p\aa{} den f\ae lles udenrigs- og sikkerhedspolitik.}
}

