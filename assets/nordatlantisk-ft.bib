  urldate = {2023-11-18},
  abstract = {2021 bringer mindst to gode grunde til at udgive et temanummer om Rigsf\ae llesskabets arktiske relationer. For det f\o rste er det 300 \aa r siden, at Hans Egede gik i land p\aa{} Haabets \O{} -- lidt uden for nutidens Nuuk -- og dermed p\aa begyndte den kolonisering af Gr\o nland, som stadig s\ae tter rammerne for alle diskussioner af forholdet til Danmark. For det andet er det planen, at Danmarks, Gr\o nlands og F\ae r\o ernes regeringer skal blive enige om en f\ae lles arktisk strategi i \aa r.}
}

@article{jensenParliamentaryQuestionsOversight2013,
  title = {Parliamentary {{Questions}}, {{Oversight}}, and {{National Opposition Status}} in the {{European Parliament}}},
  shorttitle = {Parliamentary {{Questions}}, {{Oversight}}, and {{National Opposition Status}} Inthe},
  author = {Jensen, Christian B. and Proksch, Sven-Oliver and Slapin, Jonathan B.},
  year = 2013,
  month = may,
  journal = {Legislative Studies Quarterly},
  volume = {38},
  number = {2},
  pages = {259--282},
  issn = {0362-9805, 1939-9162},
  doi = {10.1111/lsq.12013},
  urldate = {2026-02-14},
  abstract = {This study examines when and why members of the               E               uropean               P               arliament (               EP               ) use parliamentary questions as a form of fire alarm oversight. We argue that the multilevel nature of the               EU               political system allows members of the               EP               from national opposition parties to use parliamentary questions to alert the               E               uropean Commission to governments' failures to implement               EU               policy. Representation in the               EP               provides the only avenue for such oversight for national opposition parties. Using a new sample of               EP               parliamentary questions, we demonstrate that               MEPs               from national opposition parties are more likely to alert the Commission to violations of               EU               law in their own member states. These parliamentary questions may lead the Commission to take legal action against member-state governments.},
  langid = {english}
}

